<Page
    x:Class="ProWalid.Views.SavedInvoicesPage"
    x:Name="SavedInvoicesPageRoot"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:ProWalid.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    FontFamily="{StaticResource AppFontFamily}"
    FlowDirection="RightToLeft">

    <Page.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#EEF6FF" Offset="0"/>
            <GradientStop Color="#D9ECFF" Offset="0.55"/>
            <GradientStop Color="#C4E2FF" Offset="1"/>
        </LinearGradientBrush>
    </Page.Background>

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <Style x:Key="TopActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#123C68"/>
            <Setter Property="BorderBrush" Value="#A9C8EA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="18,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="RowActionButtonStyle" TargetType="Button">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Page.Resources>

    <Grid Padding="28,22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                CornerRadius="22"
                BorderBrush="#7EB6E8"
                BorderThickness="1"
                Padding="22,18"
                Margin="0,0,0,18">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#386FA8" Offset="0"/>
                    <GradientStop Color="#4D88C4" Offset="0.6"/>
                    <GradientStop Color="#5A94D0" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Command="{Binding GoBackCommand}"
                        Style="{StaticResource TopActionButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon Symbol="Back" Foreground="#22527F"/>
                        <TextBlock Text="رجوع" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <StackPanel Grid.Column="2" Spacing="4" HorizontalAlignment="Right">
                    <TextBlock Text="{Binding HeaderTitle}"
                               FontSize="32"
                               FontWeight="Bold"
                               Foreground="White"
                               TextAlignment="Right"/>
                    <TextBlock Text="{Binding PageSubtitle}"
                               FontSize="14"
                               Foreground="#E7F4FF"
                               TextAlignment="Right"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Background="#FFFFFF"
                CornerRadius="20"
                BorderBrush="#D4E6F8"
                BorderThickness="1"
                Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="#E7F0FA"
                        CornerRadius="20,20,0,0"
                        Padding="14,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="300"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="#" FontSize="15" FontWeight="Bold" Foreground="#1D3E63" TextAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="رقم الفاتورة / التجميعة" FontSize="15" FontWeight="Bold" Foreground="#1D3E63" TextAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="التاريخ" FontSize="15" FontWeight="Bold" Foreground="#1D3E63" TextAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="المبلغ" FontSize="15" FontWeight="Bold" Foreground="#1D3E63" TextAlignment="Center"/>
                        <TextBlock Grid.Column="4" Text="العميل / الشركة" FontSize="15" FontWeight="Bold" Foreground="#1D3E63" TextAlignment="Center"/>
                        <TextBlock Grid.Column="5" Text="الإجراءات" FontSize="15" FontWeight="Bold" Foreground="#1D3E63" TextAlignment="Center"/>
                    </Grid>
                </Border>

                <ListView Grid.Row="1"
                          ItemsSource="{Binding SavedInvoiceRows}"
                          SelectionMode="None"
                          IsItemClickEnabled="False"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          Background="Transparent"
                          BorderThickness="0"
                          Padding="0">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="UseSystemFocusVisuals" Value="False"/>
                        </Style>
                    </ListView.ItemContainerStyle>

                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#EDF3F9" BorderThickness="0,0,0,1" Padding="14,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="150"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="300"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="{Binding SerialNumber}" FontSize="14" Foreground="#244C71" TextAlignment="Center" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DisplayInvoiceNumber}" FontSize="14" FontWeight="Bold" Foreground="#1B4E80" TextAlignment="Center"/>
                                        <TextBlock Text="{Binding SavedKindDisplay}" FontSize="12" Foreground="#4F6B86" TextAlignment="Center"/>
                                        <TextBlock Text="{Binding GroupedInvoicesCountText}" FontSize="12" Foreground="#4F6B86" TextAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" Text="{Binding InvoiceDateText}" FontSize="14" Foreground="#3A4F63" TextAlignment="Center" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="3" Text="{Binding TotalAmountText}" FontSize="14" Foreground="#0F766E" FontWeight="Bold" TextAlignment="Center" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="4" Spacing="4" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding CustomerName}" FontSize="14" FontWeight="SemiBold" Foreground="#273F58" TextAlignment="Center"/>
                                        <TextBlock Text="{Binding CompanyName}" FontSize="13" Foreground="#5B728A" TextAlignment="Center" TextWrapping="WrapWholeWords"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="5" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Button Command="{Binding DataContext.ShowGroupedInvoicesCommand, ElementName=SavedInvoicesPageRoot}"
                                                CommandParameter="{Binding}"
                                                Visibility="{Binding CanShowGroupedInvoiceNumbers, Converter={StaticResource BoolToVisibilityConverter}}"
                                                Style="{StaticResource RowActionButtonStyle}"
                                                Background="#FFF6E8"
                                                BorderBrush="#F3C98B"
                                                Foreground="#9A4A00">
                                            <TextBlock Text="الفواتير الأصلية"/>
                                        </Button>
                                        <Button Command="{Binding DataContext.ViewSavedInvoiceCommand, ElementName=SavedInvoicesPageRoot}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource RowActionButtonStyle}"
                                                Background="#EFF7FF"
                                                BorderBrush="#9FC6EA"
                                                Foreground="#0F5E9C">
                                            <TextBlock Text="عرض"/>
                                        </Button>
                                        <Button Command="{Binding DataContext.PrintSavedInvoiceCommand, ElementName=SavedInvoicesPageRoot}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource RowActionButtonStyle}"
                                                Background="#EAFBF3"
                                                BorderBrush="#A7E0BC"
                                                Foreground="#166534">
                                            <TextBlock Text="طباعة"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <Border Grid.Row="2"
                        Background="#F8FBFF"
                        BorderBrush="#E4EFFA"
                        BorderThickness="1,1,0,0"
                        Padding="16,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="1" Text="{Binding TotalAmountText}" FontSize="14" FontWeight="Bold" Foreground="#123B66"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Page>
