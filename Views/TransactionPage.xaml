<Page
    x:Class="ProWalid.Views.TransactionPage"
    x:Name="TransactionPageRoot"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:ProWalid.Views"
    xmlns:models="using:ProWalid.Models"
    xmlns:converters="using:ProWalid.Converters"
    mc:Ignorable="d"
    FontFamily="{StaticResource AppFontFamily}"
    FlowDirection="RightToLeft">
    
    <Page.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#E3F2FD" Offset="0.0"/>
            <GradientStop Color="#BBDEFB" Offset="0.5"/>
            <GradientStop Color="#90CAF9" Offset="1.0"/>
        </LinearGradientBrush>
    </Page.Background>

    <Page.Resources>
        <converters:StringToBoolConverter x:Key="StringToBoolConverter"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:TransactionStatusToBrushConverter x:Key="TransactionStatusToBrushConverter"/>
        <Style x:Key="ModernActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="#F8FBFF"/>
            <Setter Property="Foreground" Value="#12304A"/>
            <Setter Property="BorderBrush" Value="#A9C6EE"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style x:Key="PrimaryModernActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernActionButtonStyle}">
            <Setter Property="Background" Value="#DCEEFF"/>
            <Setter Property="BorderBrush" Value="#5D98EB"/>
            <Setter Property="Foreground" Value="#0B5394"/>
        </Style>
        <Style x:Key="DangerModernActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernActionButtonStyle}">
            <Setter Property="Background" Value="#FFF0F0"/>
            <Setter Property="BorderBrush" Value="#E28A8A"/>
            <Setter Property="Foreground" Value="#A61B1B"/>
        </Style>
        <Style x:Key="SuccessModernActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernActionButtonStyle}">
            <Setter Property="Background" Value="#EEF9F0"/>
            <Setter Property="BorderBrush" Value="#84BE8C"/>
            <Setter Property="Foreground" Value="#1B5E20"/>
        </Style>
        <Style x:Key="RaisedHeaderActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="26"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="FontFamily" Value="{StaticResource AppFontFamily}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="RaisedNeutralHeaderActionButtonStyle" TargetType="Button" BasedOn="{StaticResource RaisedHeaderActionButtonStyle}">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#1B1B1B"/>
            <Setter Property="BorderBrush" Value="#D6D6D6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="RootBorder.Background" Value="#F5F5F5"/>
                                            <Setter Target="RootBorder.BorderBrush" Value="#C0C0C0"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <VisualState.Setters>
                                            <Setter Target="RootBorder.Background" Value="#EBEBEB"/>
                                            <Setter Target="RootBorder.BorderBrush" Value="#ABABAB"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Disabled">
                                        <VisualState.Setters>
                                            <Setter Target="RootBorder.Opacity" Value="0.5"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <Border x:Name="RootBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="{TemplateBinding CornerRadius}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Padding="{TemplateBinding Padding}"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="RaisedPrimaryHeaderActionButtonStyle" TargetType="Button" BasedOn="{StaticResource RaisedHeaderActionButtonStyle}">
            <Setter Property="Background" Value="#E3F2FD"/>
            <Setter Property="Foreground" Value="#0B5394"/>
            <Setter Property="BorderBrush" Value="#5D98EB"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="RootBorder.Background" Value="#106EBE"/>
                                            <Setter Target="RootBorder.BorderBrush" Value="#005A9E"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <VisualState.Setters>
                                            <Setter Target="RootBorder.Background" Value="#005A9E"/>
                                            <Setter Target="RootBorder.BorderBrush" Value="#004578"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Disabled">
                                        <VisualState.Setters>
                                            <Setter Target="RootBorder.Opacity" Value="0.5"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <Border x:Name="RootBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="{TemplateBinding CornerRadius}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Padding="{TemplateBinding Padding}"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="RaisedReportsButtonStyle" TargetType="Button" BasedOn="{StaticResource RaisedHeaderActionButtonStyle}">
            <Setter Property="Background" Value="#EDE8FF"/>
            <Setter Property="Foreground" Value="#4F52B2"/>
            <Setter Property="BorderBrush" Value="#C9C7F7"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="RootBorder.Background" Value="#4F52B2"/>
                                            <Setter Target="RootBorder.BorderBrush" Value="#43469B"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <VisualState.Setters>
                                            <Setter Target="RootBorder.Background" Value="#43469B"/>
                                            <Setter Target="RootBorder.BorderBrush" Value="#383B85"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Disabled">
                                        <VisualState.Setters>
                                            <Setter Target="RootBorder.Opacity" Value="0.5"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <Border x:Name="RootBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="{TemplateBinding CornerRadius}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Padding="{TemplateBinding Padding}"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="RaisedDangerHeaderActionButtonStyle" TargetType="Button" BasedOn="{StaticResource RaisedHeaderActionButtonStyle}">
            <Setter Property="Background" Value="#FEECEC"/>
            <Setter Property="Foreground" Value="#A52613"/>
            <Setter Property="BorderBrush" Value="#E28A8A"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="RootBorder.Background" Value="#A52613"/>
                                            <Setter Target="RootBorder.BorderBrush" Value="#8C1D0B"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <VisualState.Setters>
                                            <Setter Target="RootBorder.Background" Value="#8C1D0B"/>
                                            <Setter Target="RootBorder.BorderBrush" Value="#751606"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Disabled">
                                        <VisualState.Setters>
                                            <Setter Target="RootBorder.Opacity" Value="0.5"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <Border x:Name="RootBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="{TemplateBinding CornerRadius}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Padding="{TemplateBinding Padding}"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="RaisedSuccessHeaderActionButtonStyle" TargetType="Button" BasedOn="{StaticResource RaisedHeaderActionButtonStyle}">
            <Setter Property="Background" Value="#E8F5E9"/>
            <Setter Property="Foreground" Value="#1B5E20"/>
            <Setter Property="BorderBrush" Value="#84BE8C"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="RootBorder.Background" Value="#0C6A0C"/>
                                            <Setter Target="RootBorder.BorderBrush" Value="#095809"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <VisualState.Setters>
                                            <Setter Target="RootBorder.Background" Value="#095809"/>
                                            <Setter Target="RootBorder.BorderBrush" Value="#064706"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Disabled">
                                        <VisualState.Setters>
                                            <Setter Target="RootBorder.Opacity" Value="0.5"/>
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <Border x:Name="RootBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="{TemplateBinding CornerRadius}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Padding="{TemplateBinding Padding}"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Padding="32,24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <Border Grid.Column="0"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,0,1,0"
                Width="300"
                Padding="16">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#E3F2FD" Offset="0.0"/>
                    <GradientStop Color="#BBDEFB" Offset="0.5"/>
                    <GradientStop Color="#90CAF9" Offset="1.0"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,16">
                    <TextBlock Text="قائمة العملاء"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="#0078D4"/>
                    
                    <Button Command="{Binding ToggleCustomerPanelCommand}"
                            Style="{StaticResource ModernActionButtonStyle}"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <SymbolIcon Symbol="List" Foreground="#0078D4"/>
                            <TextBlock Text="إظهار/إخفاء القائمة" 
                                       Foreground="#424242"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                
                <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,0,0,16">
                    <Button Command="{Binding AddCustomerCommand}"
                            Style="{StaticResource SuccessModernActionButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <SymbolIcon Symbol="Add" Foreground="#1B5E20"/>
                            <TextBlock Text="إضافة" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    
                    <Button Command="{Binding EditCustomerCommand}"
                            Style="{StaticResource PrimaryModernActionButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <SymbolIcon Symbol="Edit" Foreground="#0B5394"/>
                            <TextBlock Text="تعديل" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    
                    <Button Command="{Binding DeleteCustomerCommand}"
                            Style="{StaticResource DangerModernActionButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <SymbolIcon Symbol="Delete" Foreground="#A61B1B"/>
                            <TextBlock Text="حذف" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                
                <ScrollViewer Grid.Row="2"
                              Visibility="{Binding IsCustomerPanelVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ListView ItemsSource="{Binding Customers}"
                              SelectionMode="None"
                              IsItemClickEnabled="True"
                              ItemClick="CustomerListView_ItemClick"
                              Padding="0"
                              Background="Transparent"
                              BorderThickness="0">
                        <ListView.Resources>
                            <SolidColorBrush x:Key="ListViewItemBackground" Color="Transparent"/>
                            <SolidColorBrush x:Key="ListViewItemBackgroundPointerOver" Color="Transparent"/>
                            <SolidColorBrush x:Key="ListViewItemBackgroundPressed" Color="Transparent"/>
                            <SolidColorBrush x:Key="ListViewItemBackgroundSelected" Color="Transparent"/>
                            <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPointerOver" Color="Transparent"/>
                            <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPressed" Color="Transparent"/>
                            <SolidColorBrush x:Key="ListViewItemRevealBackground" Color="Transparent"/>
                            <SolidColorBrush x:Key="ListViewItemBorderBrush" Color="Transparent"/>
                            <SolidColorBrush x:Key="ListViewItemBorderBrushPointerOver" Color="Transparent"/>
                            <SolidColorBrush x:Key="ListViewItemBorderBrushPressed" Color="Transparent"/>
                            <SolidColorBrush x:Key="ListViewItemBorderBrushSelected" Color="Transparent"/>
                            <SolidColorBrush x:Key="ListViewItemBorderBrushSelectedPointerOver" Color="Transparent"/>
                            <SolidColorBrush x:Key="ListViewItemBorderBrushSelectedPressed" Color="Transparent"/>
                        </ListView.Resources>
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="MinHeight" Value="0"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderBrush" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="UseSystemFocusVisuals" Value="False"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:Customer">
                                <Border BorderBrush="#75CDEE"
                                        BorderThickness="1.5"
                                        CornerRadius="16"
                                        Margin="0,6"
                                        Background="#EAF9FF"
                                        Padding="1">
                                    <Border.Shadow>
                                        <ThemeShadow />
                                    </Border.Shadow>
                                    <Border Background="#F4FDFF"
                                             CornerRadius="15"
                                             Padding="14,12">
                                        <Grid ColumnSpacing="10" FlowDirection="LeftToRight">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <Grid Grid.Column="0"
                                                  ColumnSpacing="10"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Stretch"
                                                  MinWidth="0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <Border Grid.Column="0"
                                                        Background="#DDF4FF"
                                                        BorderBrush="#A7DFF7"
                                                        BorderThickness="1"
                                                        CornerRadius="10"
                                                        Padding="10,4"
                                                        VerticalAlignment="Center"
                                                        HorizontalAlignment="Left">
                                                    <StackPanel Orientation="Horizontal" Spacing="4">
                                                        <TextBlock Text="ID"
                                                                   FontSize="12"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#24506F"/>
                                                        <TextBlock Text="{Binding CustomerNumber}"
                                                                   FontSize="12"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="#24506F"/>
                                                    </StackPanel>
                                                </Border>

                                                <TextBlock Grid.Column="1"
                                                           Text="{x:Bind Name, Mode=OneWay}"
                                                           FontSize="15"
                                                           FontWeight="Bold"
                                                           Foreground="#0F3B5F"
                                                           TextAlignment="Right"
                                                           HorizontalAlignment="Stretch"
                                                           VerticalAlignment="Center"
                                                           TextWrapping="NoWrap"
                                                           TextTrimming="CharacterEllipsis"
                                                           MaxLines="1"
                                                           MinWidth="0"
                                                           Margin="4,0,0,0"/>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </ScrollViewer>
            </Grid>
        </Border>
        
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,24">
                <StackPanel Orientation="Horizontal" Spacing="16" HorizontalAlignment="Left">
                    <SymbolIcon Symbol="Document" Foreground="#0078D4" VerticalAlignment="Center"/>
                    <StackPanel Spacing="2">
                        <TextBlock Text="إدارة المعاملات" 
                                   FontSize="28" 
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                        <Border Background="#DDF4FF"
                                BorderBrush="#8ED8F8"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="10,4">
                            <TextBlock Text="{Binding SelectedCustomerHeaderText}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#0F3B5F"/>
                        </Border>
                    </StackPanel>
                </StackPanel>
                
                <Button Command="{Binding LogoutCommand}"
                        Style="{StaticResource RaisedDangerHeaderActionButtonStyle}"
                        HorizontalAlignment="Right"
                        Content="تسجيل الخروج"/>
            </Grid>

            <Grid Grid.Row="1" Margin="0,0,0,20" FlowDirection="LeftToRight">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" HorizontalAlignment="Left" FlowDirection="RightToLeft">
                    <Button Command="{Binding ShowInvoicesCommand}" Style="{StaticResource RaisedNeutralHeaderActionButtonStyle}" Content="الفواتير"/>
                    <Button Command="{Binding ShowReportsCommand}" Style="{StaticResource RaisedReportsButtonStyle}" Content="التقارير"/>
                    <Button Command="{Binding DownloadAttachmentsCommand}" Style="{StaticResource RaisedPrimaryHeaderActionButtonStyle}" Content="تحميل المرفقات"/>
                    <Button Command="{Binding DeleteAttachmentsCommand}" Style="{StaticResource RaisedDangerHeaderActionButtonStyle}" Content="حذف المرفقات"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right" FlowDirection="RightToLeft">
                    <Button Command="{Binding AddNewTransactionCommand}" Style="{StaticResource RaisedPrimaryHeaderActionButtonStyle}" Content="+ إضافة معاملة"/>
                    <Button Command="{Binding EditTransactionCommand}" Style="{StaticResource RaisedNeutralHeaderActionButtonStyle}" Content="تعديل معاملة"/>
                    <Button Command="{Binding DeleteSelectedCommand}" Style="{StaticResource RaisedDangerHeaderActionButtonStyle}" Content="حذف معاملة"/>
                    <Button Style="{StaticResource RaisedSuccessHeaderActionButtonStyle}"
                            Content="الحالة"
                            IsEnabled="{Binding HasSelectedTransaction}">
                        <Button.Flyout>
                            <Flyout Placement="BottomEdgeAlignedRight">
                                <StackPanel Spacing="8" Padding="6" MinWidth="170">
                                    <Button Content="معلق"
                                            Click="PendingStatusButton_Click"
                                            Background="#FDE68A"
                                            Foreground="#7C5A00"
                                            BorderBrush="#FACC15"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            HorizontalAlignment="Stretch"/>
                                    <Button Content="تم التسليم"
                                            Click="DeliveredStatusButton_Click"
                                            Background="#BBF7D0"
                                            Foreground="#166534"
                                            BorderBrush="#4ADE80"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            HorizontalAlignment="Stretch"/>
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                    </Button>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="#4169E1"
                        BorderBrush="#4169E1"
                        BorderThickness="1"
                        CornerRadius="8"
                        Margin="0,0,0,15">
                    <Grid Padding="16,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="300"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="250"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="300"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="تحديد" FontSize="16" FontWeight="Bold" Foreground="White" Padding="12,0" TextAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="بند الخدمة" FontSize="16" FontWeight="Bold" Foreground="White" Padding="12,0"/>
                        <TextBlock Grid.Column="2" Text="العدد" FontSize="16" FontWeight="Bold" Foreground="White" Padding="12,0" TextAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="سعر الوحدة" FontSize="16" FontWeight="Bold" Foreground="White" Padding="12,0" Margin="37,0,0,0" TextAlignment="Right"/>
                        <TextBlock Grid.Column="4" Text="الإجمالي" FontSize="16" FontWeight="Bold" Foreground="White" Padding="12,0" Margin="0,0,50,0" TextAlignment="Right"/>
                        <TextBlock Grid.Column="5" Text="اسم الشركة" FontSize="16" FontWeight="Bold" Foreground="White" Padding="12,0"/>
                        <TextBlock Grid.Column="6" Text="اسم الموظف" FontSize="16" FontWeight="Bold" Foreground="White" Padding="12,0"/>
                        <TextBlock Grid.Column="7" Text="المرفقات" FontSize="16" FontWeight="Bold" Foreground="White" Padding="12,0" TextAlignment="Center"/>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="2"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ListView
                            ItemsSource="{Binding AllItems, Mode=OneWay}"
                            SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                            SelectionMode="Single"
                            Padding="0"
                            Background="White"
                            FontFamily="{StaticResource AppFontFamily}">
                        <ListView.Resources>
                            <SolidColorBrush x:Key="ListViewItemBackground" Color="White"/>
                            <SolidColorBrush x:Key="ListViewItemBackgroundPointerOver" Color="White"/>
                            <SolidColorBrush x:Key="ListViewItemBackgroundPressed" Color="White"/>
                            <SolidColorBrush x:Key="ListViewItemBackgroundSelected" Color="White"/>
                            <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPointerOver" Color="White"/>
                            <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPressed" Color="White"/>
                            <SolidColorBrush x:Key="ListViewItemRevealBackground" Color="White"/>
                            <SolidColorBrush x:Key="ListViewItemBorderBrush" Color="Transparent"/>
                            <SolidColorBrush x:Key="ListViewItemBorderBrushPointerOver" Color="Transparent"/>
                            <SolidColorBrush x:Key="ListViewItemBorderBrushPressed" Color="Transparent"/>
                            <SolidColorBrush x:Key="ListViewItemBorderBrushSelected" Color="Transparent"/>
                            <SolidColorBrush x:Key="ListViewItemBorderBrushSelectedPointerOver" Color="Transparent"/>
                            <SolidColorBrush x:Key="ListViewItemBorderBrushSelectedPressed" Color="Transparent"/>
                        </ListView.Resources>
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="MinHeight" Value="0"/>
                                <Setter Property="Background" Value="White"/>
                                <Setter Property="BorderBrush" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="UseSystemFocusVisuals" Value="False"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListViewItem">
                                            <Grid>
                                                <VisualStateManager.VisualStateGroups>
                                                    <VisualStateGroup x:Name="CommonStates">
                                                        <VisualState x:Name="Normal"/>
                                                        <VisualState x:Name="PointerOver">
                                                            <VisualState.Setters>
                                                                <Setter Target="ContainerBorder.Background" Value="#14CBEFFF"/>
                                                                <Setter Target="ContainerBorder.BorderBrush" Value="#86D6F3"/>
                                                            </VisualState.Setters>
                                                        </VisualState>
                                                        <VisualState x:Name="Pressed">
                                                            <VisualState.Setters>
                                                                <Setter Target="ContainerBorder.Background" Value="#20CBEFFF"/>
                                                                <Setter Target="ContainerBorder.BorderBrush" Value="#5FC1E8"/>
                                                            </VisualState.Setters>
                                                        </VisualState>
                                                        <VisualState x:Name="Selected">
                                                            <VisualState.Setters>
                                                                <Setter Target="ContainerBorder.Background" Value="#22CBEFFF"/>
                                                                <Setter Target="ContainerBorder.BorderBrush" Value="#4FAFD8"/>
                                                            </VisualState.Setters>
                                                        </VisualState>
                                                        <VisualState x:Name="PointerOverSelected">
                                                            <VisualState.Setters>
                                                                <Setter Target="ContainerBorder.Background" Value="#2CCBEFFF"/>
                                                                <Setter Target="ContainerBorder.BorderBrush" Value="#3E9CC8"/>
                                                            </VisualState.Setters>
                                                        </VisualState>
                                                        <VisualState x:Name="SelectedUnfocused">
                                                            <VisualState.Setters>
                                                                <Setter Target="ContainerBorder.Background" Value="#1CCBEFFF"/>
                                                                <Setter Target="ContainerBorder.BorderBrush" Value="#68BFDF"/>
                                                            </VisualState.Setters>
                                                        </VisualState>
                                                    </VisualStateGroup>
                                                </VisualStateManager.VisualStateGroups>

                                                <Border x:Name="ContainerBorder"
                                                        Margin="0"
                                                        Padding="0"
                                                        CornerRadius="14"
                                                        Background="Transparent"
                                                        BorderBrush="Transparent"
                                                        BorderThickness="1">
                                                    <ContentPresenter Content="{TemplateBinding Content}"
                                                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                                </Border>
                                            </Grid>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <Border CornerRadius="8,8,0,0"
                                            Background="#EAF9FF"
                                            BorderBrush="#75CDEE"
                                            BorderThickness="1.5,1.5,1.5,0"
                                            Visibility="{Binding IsFirstItemInTransaction, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <Border.Shadow>
                                            <ThemeShadow />
                                        </Border.Shadow>
                                        <Border Background="#CBEFFF" Padding="10,5" CornerRadius="15,15,0,0">
                                            <Grid FlowDirection="RightToLeft">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="3" VerticalAlignment="Center">
                                                    <TextBlock Text="فاتورة رقم:" Foreground="#0F3B5F" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding InvoiceNumber}" Foreground="#0F3B5F" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <Border Grid.Column="2"
                                                        Background="{Binding TransactionStatus, Converter={StaticResource TransactionStatusToBrushConverter}}"
                                                        CornerRadius="8"
                                                        Padding="8,3"
                                                        Margin="12,0,0,0"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding TransactionStatus}"
                                                               Foreground="{Binding TransactionStatus, Converter={StaticResource TransactionStatusToBrushConverter}, ConverterParameter=Foreground}"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                                <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="3">
                                                    <TextBlock Text="الإجمالي:" Foreground="#0F3B5F" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding TransactionTotal}" Foreground="#0F3B5F" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
                                                    <TextBlock Text="درهم" Foreground="#0F3B5F" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </Border>

                                    <Grid Padding="6,3" Background="#F4FDFF" BorderBrush="#75CDEE" BorderThickness="1.5,0,1.5,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="300"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="250"/>
                                            <ColumnDefinition Width="200"/>
                                            <ColumnDefinition Width="300"/>
                                        </Grid.ColumnDefinitions>

                                        <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected, Mode=TwoWay}" Visibility="{Binding IsFirstItemInTransaction, Converter={StaticResource BoolToVisibilityConverter}}" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="4,0"/>
                                        <TextBlock Grid.Column="1" Text="{Binding ServiceName, Mode=OneWay}" FontSize="14" Padding="10,5" VerticalAlignment="Center" Foreground="#0F3B5F" FontWeight="SemiBold"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Quantity, Mode=OneWay}" FontSize="14" Padding="10,5" VerticalAlignment="Center" TextAlignment="Center" FontWeight="SemiBold"/>
                                        <TextBlock Grid.Column="3" Text="{Binding UnitPrice, Mode=OneWay}" FontSize="14" Padding="10,5" Margin="24,0,0,0" VerticalAlignment="Center" TextAlignment="Right" Foreground="#24506F"/>
                                        <TextBlock Grid.Column="4" Text="{Binding Total, Mode=OneWay}" FontSize="14" FontWeight="Bold" Foreground="#2E7D32" Padding="10,5" Margin="0,0,28,0" VerticalAlignment="Center" TextAlignment="Right"/>
                                        <TextBlock Grid.Column="5" Text="{Binding CompanyName, Mode=OneWay}" FontSize="14" Padding="10,5" VerticalAlignment="Center" Foreground="#24506F"/>
                                        <TextBlock Grid.Column="6" Text="{Binding EmployeeName, Mode=OneWay}" FontSize="14" Padding="10,5" VerticalAlignment="Center" Foreground="#24506F"/>

                                        <ItemsControl Grid.Column="7" ItemsSource="{Binding Attachments}" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="4,0">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="4" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Button Command="{Binding DataContext.OpenAttachmentCommand, ElementName=TransactionPageRoot}"
                                                            CommandParameter="{Binding}"
                                                            Width="28"
                                                            Height="28"
                                                            Padding="0"
                                                            Background="#EEF7FF"
                                                            BorderBrush="#CFE8FF"
                                                            BorderThickness="1"
                                                            CornerRadius="8"
                                                            ToolTipService.ToolTip="{Binding OriginalFileName}">
                                                        <Grid>
                                                            <FontIcon Glyph="&#xE8A5;"
                                                                      FontSize="14"
                                                                      Foreground="#C62828"
                                                                      Visibility="{Binding IsPdfAttachment, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                            <SymbolIcon Symbol="Pictures"
                                                                        Foreground="#0B6FA4"
                                                                        Visibility="{Binding IsImageAttachment, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                            <SymbolIcon Symbol="Document"
                                                                        Foreground="#0B6FA4"
                                                                        Visibility="{Binding IsOtherAttachment, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                        </Grid>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>

                                    <Border Height="1"
                                            Background="#F4FDFF"
                                            Margin="0,0,0,4"
                                            BorderBrush="#75CDEE"
                                            BorderThickness="1.5,0,1.5,1.5"
                                            CornerRadius="0,0,16,16"
                                            Visibility="{Binding IsLastItemInTransaction, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </ScrollViewer>
            </Grid>
            <StackPanel Grid.Row="3" 
                        Orientation="Horizontal" 
                        HorizontalAlignment="Right" 
                        Spacing="12"
                   Margin="0,20,0,0">
            <TextBlock Text="عدد المعاملات: " 
                       FontSize="15" 
                       VerticalAlignment="Center"/>
            <TextBlock Text="{Binding TransactionCount, Mode=OneWay}" 
                       FontSize="15" 
                       FontWeight="Bold"
                       Foreground="#0078D4"
                       VerticalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Grid>
</Page>
