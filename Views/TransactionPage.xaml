<Page
    x:Class="ProWalid.Views.TransactionPage"
    x:Name="TransactionPageRoot"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:ProWalid.Views"
    xmlns:converters="using:ProWalid.Converters"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    FlowDirection="RightToLeft">

    <Page.Resources>
        <converters:StringToBoolConverter x:Key="StringToBoolConverter"/>
    </Page.Resources>

    <Grid Padding="32,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="16" Margin="0,0,0,24">
            <SymbolIcon Symbol="Document" Foreground="#0078D4" VerticalAlignment="Center"/>
            <TextBlock Text="إدارة المعاملات" 
                       FontSize="28" 
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" Spacing="16">
                <Button Command="{Binding AddNewTransactionCommand}"
                        Height="44"
                        Padding="20,0"
                        CornerRadius="6"
                        Background="#0078D4"
                        Foreground="White"
                        FontSize="15"
                        FontWeight="SemiBold">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon Symbol="Add" Foreground="White"/>
                        <TextBlock Text="إضافة معاملة"/>
                    </StackPanel>
                </Button>

                <Button Command="{Binding EditTransactionCommand}"
                        Height="44"
                        Padding="20,0"
                        CornerRadius="6"
                        Background="#FF8F00"
                        Foreground="White"
                        FontSize="15"
                        FontWeight="SemiBold">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon Symbol="Edit" Foreground="White"/>
                        <TextBlock Text="تعديل معاملة"/>
                    </StackPanel>
                </Button>

                <Button Command="{Binding DeleteSelectedCommand}"
                        Height="44"
                        Padding="20,0"
                        CornerRadius="6"
                        Background="#D32F2F"
                        Foreground="White"
                        FontSize="15"
                        FontWeight="SemiBold">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon Symbol="Delete" Foreground="White"/>
                        <TextBlock Text="حذف معاملة"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <TextBlock Grid.Column="1" 
                       VerticalAlignment="Center"
                       FontSize="16"
                       FontWeight="SemiBold">
                <Run Text="الإجمالي الكلي: "/>
                <Run Text="{Binding TotalAmount, Mode=OneWay}" Foreground="#0078D4"/>
                <Run Text=" ريال"/>
            </TextBlock>
        </Grid>

        <Border Grid.Row="2" 
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" 
                      Background="#F5F5F5" 
                      Padding="16,14"
                      CornerRadius="8,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="3*"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1.5*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="بند الخدمة" 
                               FontSize="16" FontWeight="Bold" 
                               Foreground="#424242" 
                               Padding="12,0"/>
                    <TextBlock Grid.Column="1" Text="العدد" 
                               FontSize="16" FontWeight="Bold" 
                               Foreground="#424242" 
                               Padding="12,0"
                               TextAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="سعر الوحدة" 
                               FontSize="16" FontWeight="Bold" 
                               Foreground="#424242" 
                               Padding="12,0"
                               Margin="37,0,0,0"
                               TextAlignment="Right"/>
                    <TextBlock Grid.Column="3" Text="الإجمالي" 
                               FontSize="16" FontWeight="Bold" 
                               Foreground="#424242" 
                               Padding="12,0"
                               Margin="0,0,50,0"
                               TextAlignment="Right"/>
                    <TextBlock Grid.Column="4" Text="اسم الشركة" 
                               FontSize="16" FontWeight="Bold" 
                               Foreground="#424242" 
                               Padding="12,0"/>
                    <TextBlock Grid.Column="5" Text="اسم الموظف" 
                               FontSize="16" FontWeight="Bold" 
                               Foreground="#424242" 
                               Padding="12,0"/>
                    <TextBlock Grid.Column="6" Text="المرفقات" 
                               FontSize="16" FontWeight="Bold" 
                               Foreground="#424242" 
                               Padding="12,0"
                               TextAlignment="Center"/>
                </Grid>

                <ListView Grid.Row="1"
                          ItemsSource="{Binding AllItems, Mode=OneWay}"
                          SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                          SelectionMode="Single"
                          Padding="0">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="MinHeight" Value="64"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="16,12" 
                                  BorderBrush="#E0E0E0" 
                                  BorderThickness="0,0,0,1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="3*"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" 
                                           Text="{Binding ServiceName, Mode=OneWay}"
                                           FontSize="15"
                                           Padding="12,8"
                                           VerticalAlignment="Center"/>

                                <TextBlock Grid.Column="1" 
                                           Text="{Binding Quantity, Mode=OneWay}"
                                           FontSize="15"
                                           Padding="12,8"
                                           VerticalAlignment="Center"
                                           TextAlignment="Center"
                                           FontWeight="SemiBold"/>

                                <TextBlock Grid.Column="2" 
                                           Text="{Binding UnitPrice, Mode=OneWay}"
                                           FontSize="15"
                                           Padding="12,8"
                                           Margin="37,0,0,0"
                                           VerticalAlignment="Center"
                                           TextAlignment="Right"/>

                                <TextBlock Grid.Column="3" 
                                           Text="{Binding Total, Mode=OneWay}"
                                           FontSize="15"
                                           FontWeight="Bold"
                                           Foreground="#2E7D32"
                                           Padding="12,8"
                                           Margin="0,0,50,0"
                                           VerticalAlignment="Center"
                                           TextAlignment="Right"/>

                                <TextBlock Grid.Column="4" 
                                           Text="{Binding CompanyName, Mode=OneWay}"
                                           FontSize="15"
                                           Padding="12,8"
                                           VerticalAlignment="Center"/>

                                <TextBlock Grid.Column="5" 
                                           Text="{Binding EmployeeName, Mode=OneWay}"
                                           FontSize="15"
                                           Padding="12,8"
                                           VerticalAlignment="Center"/>

                                <ItemsControl Grid.Column="6"
                                              ItemsSource="{Binding Attachments}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="8"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <HyperlinkButton Command="{Binding DataContext.OpenAttachmentCommand, ElementName=TransactionPageRoot}"
                                                             CommandParameter="{Binding}"
                                                             Content="{Binding OriginalFileName}"
                                                             FontSize="13"
                                                             Padding="8,4"
                                                             ToolTipService.ToolTip="{Binding OriginalFileName}"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

        <StackPanel Grid.Row="3" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    Spacing="12"
                    Margin="0,20,0,0">
            <TextBlock Text="عدد المعاملات: " 
                       FontSize="15" 
                       VerticalAlignment="Center"/>
            <TextBlock Text="{Binding TransactionCount, Mode=OneWay}" 
                       FontSize="15" 
                       FontWeight="Bold"
                       Foreground="#0078D4"
                       VerticalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Page>
