<Page
    x:Class="ProWalid.Views.AddTransactionPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    FlowDirection="RightToLeft">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Padding="40,32" MaxWidth="1400">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" 
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="28"
                    Margin="0,0,0,24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Spacing="10" Margin="0,0,20,0">
                        <TextBlock Text="رقم الفاتورة" FontWeight="SemiBold" FontSize="16"/>
                        <TextBox Text="{Binding InvoiceNumber, Mode=OneWay}"
                                 IsReadOnly="True"
                                 Background="#F5F5F5"
                                 FontSize="17"
                                 Height="48"
                                 FontWeight="Bold"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Spacing="10" Margin="0,0,20,0">
                        <TextBlock Text="اسم الشركة" FontWeight="SemiBold" FontSize="16"/>
                        <TextBox Text="{Binding CompanyName, Mode=TwoWay}"
                                 PlaceholderText="أدخل اسم الشركة"
                                 FontSize="17"
                                 Height="48"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Spacing="10" Margin="0,0,20,0">
                        <TextBlock Text="اسم الموظف" FontWeight="SemiBold" FontSize="16"/>
                        <TextBox Text="{Binding EmployeeName, Mode=TwoWay}"
                                 PlaceholderText="أدخل اسم الموظف"
                                 FontSize="17"
                                 Height="48"/>
                    </StackPanel>

                    <StackPanel Grid.Column="3" Spacing="10">
                        <TextBlock Text="التاريخ" FontWeight="SemiBold" FontSize="16"/>
                        <DatePicker Date="{Binding TransactionDate, Mode=TwoWay}"
                                    HorizontalAlignment="Stretch"
                                    FontSize="17"
                                    Height="48"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="1"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="28"
                    Margin="0,0,0,24">
                <StackPanel Spacing="20">
                    <TextBlock Text="بنود المعاملة"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="#0078D4"/>

                    <ItemsControl ItemsSource="{Binding Items}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#FAFAFA"
                                        BorderBrush="#E0E0E0"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="24"
                                        Margin="0,0,0,16">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Grid Grid.Row="0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" Spacing="10" Margin="0,0,16,0">
                                                <TextBlock Text="بند الخدمة" FontSize="15" FontWeight="SemiBold"/>
                                                <TextBox Text="{Binding ServiceName, Mode=TwoWay}"
                                                         PlaceholderText="اسم الخدمة"
                                                         FontSize="16"
                                                         Height="46"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Spacing="10" Margin="0,0,16,0">
                                                <TextBlock Text="العدد" FontSize="15" FontWeight="SemiBold"/>
                                                <NumberBox Value="{Binding Quantity, Mode=TwoWay}"
                                                           Minimum="0"
                                                           SpinButtonPlacementMode="Compact"
                                                           FontSize="16"
                                                           Height="46"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2" Spacing="10" Margin="0,0,16,0">
                                                <TextBlock Text="سعر الوحدة" FontSize="15" FontWeight="SemiBold"/>
                                                <NumberBox Value="{Binding UnitPrice, Mode=TwoWay}"
                                                           Minimum="0"
                                                           SpinButtonPlacementMode="Compact"
                                                           FontSize="16"
                                                           Height="46"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="3" Spacing="10" Margin="0,0,16,0">
                                                <TextBlock Text="الإجمالي" FontSize="15" FontWeight="SemiBold"/>
                                                <TextBox Text="{Binding Total, Mode=OneWay}"
                                                         IsReadOnly="True"
                                                         Background="#E8F5E9"
                                                         FontSize="16"
                                                         FontWeight="Bold"
                                                         Foreground="#2E7D32"
                                                         Height="46"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="4" Spacing="10" Margin="0,0,16,0">
                                                <TextBlock Text="الفائدة" FontSize="15" FontWeight="SemiBold"/>
                                                <NumberBox Value="{Binding Profit, Mode=TwoWay}"
                                                           Minimum="0"
                                                           SpinButtonPlacementMode="Compact"
                                                           FontSize="16"
                                                           Height="46"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="5" Spacing="10" Margin="0,0,16,0">
                                                <TextBlock Text="الخصم" FontSize="15" FontWeight="SemiBold"/>
                                                <NumberBox Value="{Binding Discount, Mode=TwoWay}"
                                                           Minimum="0"
                                                           SpinButtonPlacementMode="Compact"
                                                           FontSize="16"
                                                           Height="46"/>
                                            </StackPanel>

                                            <Button Grid.Column="6"
                                                    Content="🗑️"
                                                    Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource Mode=TemplatedParent}}"
                                                    CommandParameter="{Binding}"
                                                    Background="#FFEBEE"
                                                    BorderBrush="#EF5350"
                                                    FontSize="20"
                                                    Width="46"
                                                    Height="46"
                                                    CornerRadius="8"
                                                    VerticalAlignment="Bottom"
                                                    ToolTipService.ToolTip="حذف البند"/>
                                        </Grid>

                                        <StackPanel Grid.Row="1" Spacing="10" Margin="0,16,0,0">
                                            <TextBlock Text="المرفقات" FontSize="15" FontWeight="SemiBold"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBox Grid.Column="0"
                                                         Text="{Binding AttachmentPath, Mode=OneWay}"
                                                         IsReadOnly="True"
                                                         PlaceholderText="لم يتم اختيار ملف"
                                                         FontSize="16"
                                                         Height="46"
                                                         Margin="0,0,16,0"/>

                                                <Button Grid.Column="1"
                                                        Content="📎 اختيار ملف"
                                                        Command="{Binding DataContext.PickFileCommand, RelativeSource={RelativeSource Mode=TemplatedParent}}"
                                                        CommandParameter="{Binding}"
                                                        Background="#0078D4"
                                                        Foreground="White"
                                                        Height="46"
                                                        Padding="24,0"
                                                        CornerRadius="8"
                                                        FontSize="16"/>
                                            </Grid>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Grid.Row="2"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="28">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="16">
                        <Button Command="{Binding AddItemCommand}"
                                Background="#0078D4"
                                Foreground="White"
                                Height="50"
                                Padding="28,0"
                                CornerRadius="8"
                                FontSize="16"
                                FontWeight="SemiBold">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <SymbolIcon Symbol="Add" Foreground="White"/>
                                <TextBlock Text="إضافة بند"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding SaveCommand}"
                                Background="#2E7D32"
                                Foreground="White"
                                Height="50"
                                Padding="28,0"
                                CornerRadius="8"
                                FontSize="16"
                                FontWeight="SemiBold">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <SymbolIcon Symbol="Save" Foreground="White"/>
                                <TextBlock Text="حفظ المعاملة"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding CancelCommand}"
                                Background="#D32F2F"
                                Foreground="White"
                                Height="50"
                                Padding="28,0"
                                CornerRadius="8"
                                FontSize="16"
                                FontWeight="SemiBold">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <SymbolIcon Symbol="Cancel" Foreground="White"/>
                                <TextBlock Text="إلغاء المعاملة"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <Border Grid.Column="2"
                            Background="#E3F2FD"
                            BorderBrush="#0078D4"
                            BorderThickness="2"
                            CornerRadius="8"
                            Padding="24,12">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="إجمالي مبلغ البنود:"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding GrandTotal, Mode=OneWay}"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="#0078D4"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="ريال"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
