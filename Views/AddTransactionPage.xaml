<Page
    x:Class="ProWalid.Views.AddTransactionPage"
    x:Name="AddTransactionPageRoot"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:converters="using:ProWalid.Converters"
    xmlns:models="using:ProWalid.Models"
    mc:Ignorable="d"
    Background="#F7FAFC"
    FlowDirection="RightToLeft">

    <Page.Resources>
        <converters:ValidationBrushConverter x:Key="ValidationBrushConverter"/>
        <converters:NumericTextConverter x:Key="NumericTextConverter"/>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="PlaceholderForeground" Value="#7F8B99"/>
            <Setter Property="TextAlignment" Value="Right"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="IsSpellCheckEnabled" Value="False"/>
        </Style>
        <Style TargetType="AutoSuggestBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="UpdateTextOnSelect" Value="True"/>
        </Style>
        <Style TargetType="DatePicker">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="34"/>
        </Style>
        <DataTemplate x:Key="SuggestionItemTemplate" x:DataType="models:SuggestionEntry">
            <Grid FlowDirection="LeftToRight">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding Value}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           Margin="0,0,8,0"
                           Foreground="#1F2937"/>

                <Button Grid.Column="1"
                        Content="✕"
                        Tag="{Binding}"
                        Click="DeleteSuggestionButton_Click"
                        ClickMode="Press"
                        Width="24"
                        Height="24"
                        CornerRadius="12"
                        Background="#FFF1F2"
                        BorderBrush="#F5C2C7"
                        Foreground="#C62828"
                        BorderThickness="1"
                        Padding="0"
                        FontSize="11"
                        FontWeight="Bold"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>
            </Grid>
        </DataTemplate>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="#F7FAFC">
        <Grid Padding="18,10" MaxWidth="1180" HorizontalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" 
                    Background="White"
                    BorderBrush="#DCE7F0"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="14"
                    Margin="0,0,0,10">
                <StackPanel Spacing="10">
                    <Border Background="#EEF8FF"
                            BorderBrush="#C9E6FA"
                            BorderThickness="1"
                            CornerRadius="8"
                            Padding="10,6"
                            HorizontalAlignment="Stretch">
                        <TextBlock Text="{Binding SelectedCustomerContextText}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="#0F3B5F"/>
                    </Border>

                    <Grid HorizontalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="270"/>
                            <ColumnDefinition Width="270"/>
                            <ColumnDefinition Width="180"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,12,0">
                            <TextBlock Text="رقم الفاتورة" FontWeight="SemiBold" FontSize="13" Foreground="#26415A"/>
                            <Border BorderBrush="#111111"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                <TextBox Text="{Binding InvoiceNumber, Mode=OneWay}"
                                         IsReadOnly="True"
                                         PlaceholderText="رقم مؤقت يُثبت عند الحفظ الناجح"
                                         Background="#F4F7FA"
                                         FontWeight="Bold"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="4" Margin="0,0,12,0">
                            <TextBlock Text="اسم الشركة" FontWeight="SemiBold" FontSize="13" Foreground="#26415A"/>
                            <Border BorderBrush="{Binding CompanyName, Converter={StaticResource ValidationBrushConverter}}"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                <AutoSuggestBox Text="{Binding CompanyName, Mode=TwoWay}"
                                                ItemsSource="{Binding CompanySuggestions}"
                                                ItemTemplate="{StaticResource SuggestionItemTemplate}"
                                                PlaceholderText="أدخل اسم الشركة"
                                                TextChanged="CompanyNameAutoSuggestBox_TextChanged"
                                                SuggestionChosen="CompanyNameAutoSuggestBox_SuggestionChosen"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Spacing="4" Margin="0,0,12,0">
                            <TextBlock Text="اسم الموظف" FontWeight="SemiBold" FontSize="13" Foreground="#26415A"/>
                            <Border BorderBrush="{Binding EmployeeName, Converter={StaticResource ValidationBrushConverter}}"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                <AutoSuggestBox Text="{Binding EmployeeName, Mode=TwoWay}"
                                                ItemsSource="{Binding EmployeeSuggestions}"
                                                ItemTemplate="{StaticResource SuggestionItemTemplate}"
                                                PlaceholderText="أدخل اسم الموظف"
                                                TextChanged="EmployeeNameAutoSuggestBox_TextChanged"
                                                SuggestionChosen="EmployeeNameAutoSuggestBox_SuggestionChosen"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="3" Spacing="4">
                            <TextBlock Text="التاريخ" FontWeight="SemiBold" FontSize="13" Foreground="#26415A"/>
                            <Border BorderBrush="#111111"
                                    BorderThickness="1"
                                    CornerRadius="6">
                                <DatePicker Date="{Binding TransactionDate, Mode=TwoWay}"
                                             HorizontalAlignment="Stretch"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.Row="1"
                    Background="White"
                    BorderBrush="#DCE7F0"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="12"
                    Margin="0,0,0,10">
                <StackPanel Spacing="8">
                    <Grid HorizontalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="250"/>
                            <ColumnDefinition Width="86"/>
                            <ColumnDefinition Width="96"/>
                            <ColumnDefinition Width="96"/>
                            <ColumnDefinition Width="96"/>
                            <ColumnDefinition Width="96"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="بند الخدمة" FontSize="12" FontWeight="SemiBold" Foreground="#61758A" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="العدد" FontSize="12" FontWeight="SemiBold" Foreground="#61758A" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="سعر الوحدة" FontSize="12" FontWeight="SemiBold" Foreground="#61758A" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="الإجمالي" FontSize="12" FontWeight="SemiBold" Foreground="#61758A" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="4" Text="الفائدة" FontSize="12" FontWeight="SemiBold" Foreground="#61758A" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="5" Text="GOV-FEES" FontSize="12" FontWeight="SemiBold" Foreground="#61758A" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="6" Text="مرفقات" FontSize="12" FontWeight="SemiBold" Foreground="#61758A" HorizontalAlignment="Center"/>
                    </Grid>

                    <ItemsControl ItemsSource="{Binding Items}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White"
                                        BorderBrush="#E4EBF2"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="8,6"
                                        Margin="0,0,0,6">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Grid Grid.Row="0" HorizontalAlignment="Center">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="250"/>
                                                <ColumnDefinition Width="86"/>
                                                <ColumnDefinition Width="96"/>
                                                <ColumnDefinition Width="96"/>
                                                <ColumnDefinition Width="96"/>
                                                <ColumnDefinition Width="96"/>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="40"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0" BorderBrush="{Binding ServiceName, Converter={StaticResource ValidationBrushConverter}}" BorderThickness="1" CornerRadius="6" Margin="0,0,6,0">
                                                <AutoSuggestBox Text="{Binding ServiceName, Mode=TwoWay}"
                                                                ItemsSource="{Binding ItemSuggestions}"
                                                                ItemTemplate="{StaticResource SuggestionItemTemplate}"
                                                                PlaceholderText="اسم الخدمة"
                                                                TextChanged="ItemDescriptionAutoSuggestBox_TextChanged"
                                                                SuggestionChosen="ItemDescriptionAutoSuggestBox_SuggestionChosen"/>
                                            </Border>

                                            <Border Grid.Column="1" BorderBrush="{Binding Quantity, Converter={StaticResource ValidationBrushConverter}, ConverterParameter=numeric}" BorderThickness="1" CornerRadius="6" Margin="0,0,6,0">
                                                <TextBox Text="{Binding Quantity, Mode=TwoWay, Converter={StaticResource NumericTextConverter}}" PlaceholderText="العدد" InputScope="Number"/>
                                            </Border>

                                            <Border Grid.Column="2" BorderBrush="{Binding UnitPrice, Converter={StaticResource ValidationBrushConverter}, ConverterParameter=numeric}" BorderThickness="1" CornerRadius="6" Margin="0,0,6,0">
                                                <TextBox Text="{Binding UnitPrice, Mode=TwoWay, Converter={StaticResource NumericTextConverter}}" PlaceholderText="السعر" InputScope="Number"/>
                                            </Border>

                                            <Border Grid.Column="3" BorderBrush="#2F855A" BorderThickness="1" CornerRadius="6" Margin="0,0,6,0">
                                                <TextBox Text="{Binding Total, Mode=OneWay}" IsReadOnly="True" Background="#EEF8F0" FontWeight="Bold" Foreground="#2E7D32"/>
                                            </Border>

                                            <Border Grid.Column="4" BorderBrush="#111111" BorderThickness="1" CornerRadius="6" Margin="0,0,6,0">
                                                <TextBox Text="{Binding Profit, Mode=TwoWay, Converter={StaticResource NumericTextConverter}}" PlaceholderText="الفائدة" Background="#FCFDFE" InputScope="Number"/>
                                            </Border>

                                            <Border Grid.Column="5" BorderBrush="#111111" BorderThickness="1" CornerRadius="6" Margin="0,0,6,0">
                                                <TextBox Text="{Binding GovFees, Mode=TwoWay}" PlaceholderText="قيمة حكومية" Background="#FCFDFE"/>
                                            </Border>

                                            <Button Grid.Column="6"
                                                    Content="إرفاق"
                                                    Command="{Binding DataContext.PickFilesCommand, ElementName=AddTransactionPageRoot}"
                                                    CommandParameter="{Binding}"
                                                    Background="#EEF5FF"
                                                    Foreground="#0F5E9C"
                                                    BorderBrush="#B9D6F2"
                                                    BorderThickness="1"
                                                    Height="30"
                                                    Padding="10,0"
                                                    CornerRadius="6"
                                                    FontSize="12"
                                                    FontWeight="SemiBold"
                                                    Margin="0,0,6,0"/>

                                            <Button Grid.Column="7"
                                                    Content="✕"
                                                    Command="{Binding DataContext.RemoveItemCommand, ElementName=AddTransactionPageRoot}"
                                                    CommandParameter="{Binding}"
                                                    Background="#FFF1F2"
                                                    BorderBrush="#F5C2C7"
                                                    Foreground="#C62828"
                                                    FontSize="12"
                                                    Width="30"
                                                    Height="30"
                                                    CornerRadius="6"
                                                    VerticalAlignment="Center"/>
                                        </Grid>

                                        <Grid Grid.Row="1" Margin="0,4,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="72"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0" Text="المرفقات" FontSize="11" FontWeight="SemiBold" Foreground="#61758A" VerticalAlignment="Center" Margin="0,0,8,0"/>

                                            <ListView Grid.Column="1"
                                                      ItemsSource="{Binding Attachments}"
                                                      MaxHeight="56"
                                                      Background="#FCFDFE"
                                                      BorderBrush="#E4EBF2"
                                                      BorderThickness="1"
                                                      CornerRadius="6"
                                                      Padding="4">
                                                <ListView.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Padding="6,4" Background="White" BorderBrush="#E4EBF2" BorderThickness="1" CornerRadius="4" Margin="0,2">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>

                                                            <Button Grid.Column="0"
                                                                    Grid.ColumnSpan="3"
                                                                    Background="Transparent"
                                                                    BorderThickness="0"
                                                                    HorizontalAlignment="Stretch"
                                                                    HorizontalContentAlignment="Stretch"
                                                                    Padding="0"
                                                                    Command="{Binding DataContext.PreviewAttachmentCommand, ElementName=AddTransactionPageRoot}"
                                                                    CommandParameter="{Binding}">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>

                                                                    <TextBlock Grid.Column="0" Text="📄" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>

                                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                                        <TextBlock Text="{Binding OriginalFileName}" FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                                                        <TextBlock Text="{Binding FileExtension}" FontSize="10" Foreground="#757575"/>
                                                                    </StackPanel>

                                                                    <TextBlock Grid.Column="2" Text="{Binding FileSize}" FontSize="10" Foreground="#757575" VerticalAlignment="Center" Margin="8,0"/>
                                                                </Grid>
                                                            </Button>

                                                            <Button Grid.Column="3" Content="✕" Background="#FFF1F2" BorderBrush="#F5C2C7" Foreground="#C62828" FontSize="11" Width="24" Height="24" CornerRadius="4" VerticalAlignment="Center" ToolTipService.ToolTip="حذف المرفق"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ListView.ItemTemplate>
                                            </ListView>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Grid.Row="2"
                    Background="White"
                    BorderBrush="#DCE7F0"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                        <Button Command="{Binding AddItemCommand}"
                                Background="#EEF5FF"
                                Foreground="#0F5E9C"
                                BorderBrush="#B9D6F2"
                                BorderThickness="1"
                                Height="30"
                                Padding="10,0"
                                CornerRadius="6"
                                FontSize="12"
                                FontWeight="SemiBold">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <SymbolIcon Symbol="Add" Foreground="#0F5E9C"/>
                                <TextBlock Text="إضافة بند"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding SaveCommand}"
                                Background="#EEF8F0"
                                Foreground="#166534"
                                BorderBrush="#B7D9C1"
                                BorderThickness="1"
                                Height="30"
                                Padding="10,0"
                                CornerRadius="6"
                                FontSize="12"
                                FontWeight="SemiBold">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <SymbolIcon Symbol="Save" Foreground="#166534"/>
                                <TextBlock Text="حفظ المعاملة"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding CancelCommand}"
                                Background="#FFF1F2"
                                Foreground="#B42318"
                                BorderBrush="#F5C2C7"
                                BorderThickness="1"
                                Height="30"
                                Padding="10,0"
                                CornerRadius="6"
                                FontSize="12"
                                FontWeight="SemiBold">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <SymbolIcon Symbol="Cancel" Foreground="#B42318"/>
                                <TextBlock Text="إلغاء المعاملة"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <Border Grid.Column="2"
                            Background="#FAF5FF"
                            BorderBrush="#D8B4FE"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="10,6"
                            Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="إجمالي الفايدة:"
                                       FontSize="13"
                                       FontWeight="Bold"
                                       Foreground="#6D28D9"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding TotalProfit, Mode=OneWay}"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Foreground="#6D28D9"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="3"
                            Background="#EFF7FF"
                            BorderBrush="#BFDBFE"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="10,6">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="إجمالي مبلغ البنود:"
                                       FontSize="13"
                                       FontWeight="Bold"
                                       Foreground="#0F5E9C"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding GrandTotal, Mode=OneWay}"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Foreground="#0078D4"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
