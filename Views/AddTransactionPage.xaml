<Page
    x:Class="ProWalid.Views.AddTransactionPage"
    x:Name="AddTransactionPageRoot"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:converters="using:ProWalid.Converters"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    FlowDirection="RightToLeft">

    <Page.Resources>
        <converters:ValidationBrushConverter x:Key="ValidationBrushConverter"/>
        <converters:NumericTextConverter x:Key="NumericTextConverter"/>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Padding="32,24" MaxWidth="1220" HorizontalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" 
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="24"
                    Margin="0,0,0,24">
                <StackPanel Spacing="18">
                    <Border Background="#DDF4FF"
                            BorderBrush="#8ED8F8"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="12,8"
                            HorizontalAlignment="Stretch">
                        <TextBlock Text="{Binding SelectedCustomerContextText}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="#0F3B5F"/>
                    </Border>

                    <Grid HorizontalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220"/>
                            <ColumnDefinition Width="340"/>
                            <ColumnDefinition Width="340"/>
                            <ColumnDefinition Width="220"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="10" Margin="0,0,20,0">
                            <TextBlock Text="رقم الفاتورة" FontWeight="SemiBold" FontSize="16"/>
                            <Border BorderBrush="#D6D6D6"
                                    BorderThickness="2"
                                    CornerRadius="6">
                                <TextBox Text="{Binding InvoiceNumber, Mode=OneWay}"
                                         IsReadOnly="True"
                                         PlaceholderText="رقم مؤقت يُثبت عند الحفظ الناجح"
                                         Background="#F5F5F5"
                                         FontSize="17"
                                         Height="48"
                                         FontWeight="Bold"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="10" Margin="0,0,20,0">
                            <TextBlock Text="اسم الشركة" FontWeight="SemiBold" FontSize="16"/>
                            <Border BorderBrush="{Binding CompanyName, Converter={StaticResource ValidationBrushConverter}}"
                                    BorderThickness="2"
                                    CornerRadius="6">
                                <TextBox Text="{Binding CompanyName, Mode=TwoWay}"
                                         PlaceholderText="أدخل اسم الشركة"
                                         FontSize="17"
                                         Height="48"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Spacing="10" Margin="0,0,20,0">
                            <TextBlock Text="اسم الموظف" FontWeight="SemiBold" FontSize="16"/>
                            <Border BorderBrush="{Binding EmployeeName, Converter={StaticResource ValidationBrushConverter}}"
                                    BorderThickness="2"
                                    CornerRadius="6">
                                <TextBox Text="{Binding EmployeeName, Mode=TwoWay}"
                                         PlaceholderText="أدخل اسم الموظف"
                                         FontSize="17"
                                         Height="48"/>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="3" Spacing="10">
                            <TextBlock Text="التاريخ" FontWeight="SemiBold" FontSize="16"/>
                            <Border BorderBrush="ForestGreen"
                                    BorderThickness="2"
                                    CornerRadius="6">
                                <DatePicker Date="{Binding TransactionDate, Mode=TwoWay}"
                                            HorizontalAlignment="Stretch"
                                            FontSize="17"
                                            Height="48"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.Row="1"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="24"
                    Margin="0,0,0,24">
                <StackPanel Spacing="20">
                    <TextBlock Text="بنود المعاملة"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="#0078D4"/>

                    <ItemsControl ItemsSource="{Binding Items}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#FAFAFA"
                                        BorderBrush="#E0E0E0"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="18"
                                        Margin="0,0,0,16">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Grid Grid.Row="0" HorizontalAlignment="Center">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="320"/>
                                                <ColumnDefinition Width="130"/>
                                                <ColumnDefinition Width="130"/>
                                                <ColumnDefinition Width="130"/>
                                                <ColumnDefinition Width="130"/>
                                                <ColumnDefinition Width="130"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" Spacing="10" Margin="0,0,16,0">
                                                <TextBlock Text="بند الخدمة" FontSize="15" FontWeight="SemiBold"/>
                                                <Border BorderBrush="{Binding ServiceName, Converter={StaticResource ValidationBrushConverter}}"
                                                        BorderThickness="2"
                                                        CornerRadius="6">
                                                    <TextBox Text="{Binding ServiceName, Mode=TwoWay}"
                                                             PlaceholderText="اسم الخدمة"
                                                             FontSize="16"
                                                             Height="46"/>
                                                </Border>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Spacing="10" Margin="0,0,16,0">
                                                <TextBlock Text="العدد" FontSize="15" FontWeight="SemiBold"/>
                                                <Border BorderBrush="{Binding Quantity, Converter={StaticResource ValidationBrushConverter}, ConverterParameter=numeric}"
                                                        BorderThickness="2"
                                                        CornerRadius="6">
                                                    <TextBox Text="{Binding Quantity, Mode=TwoWay, Converter={StaticResource NumericTextConverter}}"
                                                             PlaceholderText="العدد"
                                                             InputScope="Number"
                                                             FontSize="16"
                                                             Height="46"/>
                                                </Border>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2" Spacing="10" Margin="0,0,16,0">
                                                <TextBlock Text="سعر الوحدة" FontSize="15" FontWeight="SemiBold"/>
                                                <Border BorderBrush="{Binding UnitPrice, Converter={StaticResource ValidationBrushConverter}, ConverterParameter=numeric}"
                                                        BorderThickness="2"
                                                        CornerRadius="6">
                                                    <TextBox Text="{Binding UnitPrice, Mode=TwoWay, Converter={StaticResource NumericTextConverter}}"
                                                             PlaceholderText="السعر"
                                                             InputScope="Number"
                                                             FontSize="16"
                                                             Height="46"/>
                                                </Border>
                                            </StackPanel>

                                            <StackPanel Grid.Column="3" Spacing="10" Margin="0,0,16,0">
                                                <TextBlock Text="الإجمالي" FontSize="15" FontWeight="SemiBold"/>
                                                <Border BorderBrush="ForestGreen"
                                                        BorderThickness="2"
                                                        CornerRadius="6">
                                                    <TextBox Text="{Binding Total, Mode=OneWay}"
                                                             IsReadOnly="True"
                                                             Background="#E8F5E9"
                                                             FontSize="16"
                                                             FontWeight="Bold"
                                                             Foreground="#2E7D32"
                                                             Height="46"/>
                                                </Border>
                                            </StackPanel>

                                            <StackPanel Grid.Column="4" Spacing="10" Margin="0,0,16,0">
                                                <TextBlock Text="الفائدة" FontSize="15" FontWeight="SemiBold"/>
                                                <Border BorderBrush="#D6D6D6"
                                                        BorderThickness="2"
                                                        CornerRadius="6">
                                                    <TextBox Text="{Binding Profit, Mode=TwoWay, Converter={StaticResource NumericTextConverter}}"
                                                             PlaceholderText="قيمة للعرض فقط"
                                                             Background="#FAFAFA"
                                                             InputScope="Number"
                                                             FontSize="16"
                                                             Height="46"/>
                                                </Border>
                                            </StackPanel>

                                            <StackPanel Grid.Column="5" Spacing="10" Margin="0,0,16,0">
                                                <TextBlock Text="GOV-FEES" FontSize="15" FontWeight="SemiBold"/>
                                                <Border BorderBrush="#D6D6D6"
                                                        BorderThickness="2"
                                                        CornerRadius="6">
                                                    <TextBox Text="{Binding GovFees, Mode=TwoWay}"
                                                             PlaceholderText="قيمة حكومية للعرض فقط"
                                                             Background="#FAFAFA"
                                                             FontSize="16"
                                                             Height="46"/>
                                                </Border>
                                            </StackPanel>

                                            <Button Grid.Column="6"
                                                    Content="🗑️"
                                                    Command="{Binding DataContext.RemoveItemCommand, ElementName=AddTransactionPageRoot}"
                                                    CommandParameter="{Binding}"
                                                    Background="#FFEBEE"
                                                    BorderBrush="#EF5350"
                                                    FontSize="20"
                                                    Width="46"
                                                    Height="46"
                                                    CornerRadius="8"
                                                    VerticalAlignment="Bottom"
                                                    ToolTipService.ToolTip="حذف البند"/>
                                        </Grid>

                                        <StackPanel Grid.Row="1" Spacing="10" Margin="0,16,0,0">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                
                                                <TextBlock Grid.Column="0" 
                                                           Text="المرفقات" 
                                                           FontSize="15" 
                                                           FontWeight="SemiBold"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,16,0"/>
                                                
                                                <Button Grid.Column="1"
                                                        Content="📎 إرفاق ملفات"
                                                        Command="{Binding DataContext.PickFilesCommand, ElementName=AddTransactionPageRoot}"
                                                        CommandParameter="{Binding}"
                                                        Background="#0078D4"
                                                        Foreground="White"
                                                        Height="40"
                                                        Padding="20,0"
                                                        CornerRadius="6"
                                                        FontSize="15"
                                                        HorizontalAlignment="Left"/>
                                            </Grid>

                                            <ListView ItemsSource="{Binding Attachments}"
                                                      MaxHeight="150"
                                                      Background="#F9F9F9"
                                                      BorderBrush="#E0E0E0"
                                                      BorderThickness="1"
                                                      CornerRadius="6"
                                                      Padding="8">
                                                <ListView.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Padding="8,6"
                                                              Background="White"
                                                              BorderBrush="#E0E0E0"
                                                              BorderThickness="1"
                                                              CornerRadius="4"
                                                              Margin="0,4">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>

                                                            <Button Grid.Column="0"
                                                                    Grid.ColumnSpan="3"
                                                                    Background="Transparent"
                                                                    BorderThickness="0"
                                                                    HorizontalAlignment="Stretch"
                                                                    HorizontalContentAlignment="Stretch"
                                                                    Padding="0"
                                                                    Command="{Binding DataContext.PreviewAttachmentCommand, ElementName=AddTransactionPageRoot}"
                                                                    CommandParameter="{Binding}">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>

                                                                    <TextBlock Grid.Column="0"
                                                                               Text="📄"
                                                                               FontSize="18"
                                                                               VerticalAlignment="Center"
                                                                               Margin="0,0,12,0"/>

                                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                                        <TextBlock Text="{Binding OriginalFileName}"
                                                                                   FontSize="14"
                                                                                   FontWeight="SemiBold"
                                                                                   TextTrimming="CharacterEllipsis"/>
                                                                        <TextBlock Text="{Binding FileExtension}"
                                                                                   FontSize="12"
                                                                                   Foreground="#757575"/>
                                                                    </StackPanel>

                                                                    <TextBlock Grid.Column="2"
                                                                               Text="{Binding FileSize}"
                                                                               FontSize="12"
                                                                               Foreground="#757575"
                                                                               VerticalAlignment="Center"
                                                                               Margin="12,0"/>
                                                                </Grid>
                                                            </Button>

                                                            <Button Grid.Column="3"
                                                                    Content="🗑️"
                                                                    Background="#FFEBEE"
                                                                    BorderBrush="#EF5350"
                                                                    FontSize="14"
                                                                    Width="32"
                                                                    Height="32"
                                                                    CornerRadius="4"
                                                                    VerticalAlignment="Center"
                                                                    ToolTipService.ToolTip="حذف المرفق"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ListView.ItemTemplate>
                                            </ListView>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <Border Grid.Row="2"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="28">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="16">
                        <Button Command="{Binding AddItemCommand}"
                                Background="#1E88E5"
                                Foreground="White"
                                Height="42"
                                Padding="18,0"
                                CornerRadius="10"
                                FontSize="14"
                                FontWeight="SemiBold">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <SymbolIcon Symbol="Add" Foreground="White"/>
                                <TextBlock Text="إضافة بند"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding SaveCommand}"
                                Background="#2E7D32"
                                Foreground="White"
                                Height="42"
                                Padding="18,0"
                                CornerRadius="10"
                                FontSize="14"
                                FontWeight="SemiBold">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <SymbolIcon Symbol="Save" Foreground="White"/>
                                <TextBlock Text="حفظ المعاملة"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding CancelCommand}"
                                Background="#D32F2F"
                                Foreground="White"
                                Height="42"
                                Padding="18,0"
                                CornerRadius="10"
                                FontSize="14"
                                FontWeight="SemiBold">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <SymbolIcon Symbol="Cancel" Foreground="White"/>
                                <TextBlock Text="إلغاء المعاملة"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <Border Grid.Column="2"
                            Background="#F3E8FF"
                            BorderBrush="#7C3AED"
                            BorderThickness="2"
                            CornerRadius="8"
                            Padding="24,12"
                            Margin="0,0,16,0">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="إجمالي الفايدة:"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding TotalProfit, Mode=OneWay}"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="#6D28D9"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="درهم إماراتي"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="3"
                            Background="#E3F2FD"
                            BorderBrush="#0078D4"
                            BorderThickness="2"
                            CornerRadius="8"
                            Padding="24,12">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <TextBlock Text="إجمالي مبلغ البنود:"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding GrandTotal, Mode=OneWay}"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="#0078D4"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="درهم إماراتي"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
