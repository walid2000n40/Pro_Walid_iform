<Page
    x:Class="ProWalid.Views.InvoicesPage"
    x:Name="InvoicesPageRoot"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    FontFamily="{StaticResource AppFontFamily}"
    FlowDirection="RightToLeft">

    <Page.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#EEF6FF" Offset="0"/>
            <GradientStop Color="#D9ECFF" Offset="0.55"/>
            <GradientStop Color="#C4E2FF" Offset="1"/>
        </LinearGradientBrush>
    </Page.Background>

    <Page.Resources>
        <Style x:Key="TopActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#123C68"/>
            <Setter Property="BorderBrush" Value="#A9C8EA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="18,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="ModernToolbarButtonStyle" TargetType="Button" BasedOn="{StaticResource TopActionButtonStyle}">
            <Setter Property="Padding" Value="18,12"/>
            <Setter Property="MinWidth" Value="152"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="FontSize" Value="15"/>
        </Style>

        <Style x:Key="RowActionButtonStyle" TargetType="Button">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
    </Page.Resources>

    <Grid Padding="28,22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                CornerRadius="22"
                BorderBrush="#7EB6E8"
                BorderThickness="1"
                Padding="22,18"
                Margin="0,0,0,18">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#386FA8" Offset="0"/>
                    <GradientStop Color="#4D88C4" Offset="0.6"/>
                    <GradientStop Color="#5A94D0" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Command="{Binding GoBackCommand}"
                            Style="{StaticResource TopActionButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <SymbolIcon Symbol="Back" Foreground="#22527F"/>
                            <TextBlock Text="رجوع" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <StackPanel Grid.Column="2" Spacing="4" HorizontalAlignment="Right">
                        <TextBlock Text="{Binding HeaderTitle}"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   TextAlignment="Right"/>
                        <TextBlock Text="{Binding PageSubtitle}"
                                   FontSize="14"
                                   Foreground="#E7F4FF"
                                   TextAlignment="Right"/>
                    </StackPanel>
                </Grid>

                <ScrollViewer Grid.Row="1"
                              Margin="0,18,0,0"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled"
                              HorizontalScrollMode="Enabled"
                              VerticalScrollMode="Disabled"
                              ZoomMode="Disabled">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <Button Command="{Binding ShowSavedInvoicesCommand}"
                                Style="{StaticResource ModernToolbarButtonStyle}"
                                Background="#F7FBFF"
                                Foreground="#0E558B">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <SymbolIcon Symbol="Library" Foreground="#0E73B8"/>
                                <TextBlock Text="الفواتير المحفوظة" VerticalAlignment="Center"/>
                                <Border Background="#D8EEFF" CornerRadius="10" Padding="8,2">
                                    <TextBlock Text="{Binding SavedInvoicesBadgeText}" Foreground="#0B62A2" FontWeight="Bold" FontSize="12"/>
                                </Border>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding ShowInvoicePreviewCommand}"
                                Style="{StaticResource ModernToolbarButtonStyle}"
                                Background="#EEF2FF"
                                Foreground="#3730A3">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <SymbolIcon Symbol="Preview" Foreground="#4F46E5"/>
                                <TextBlock Text="معاينة النماذج" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding ShowGroupedInvoiceCommand}"
                                Style="{StaticResource ModernToolbarButtonStyle}"
                                Background="#FFF4E8"
                                Foreground="#9A4A00">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <SymbolIcon Symbol="AllApps" Foreground="#D97706"/>
                                <TextBlock Text="فاتورة مجمعة" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding ShowInvoiceNumberTwoCommand}"
                                Style="{StaticResource ModernToolbarButtonStyle}"
                                Background="#F3EBFF"
                                Foreground="#6B21A8">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <SymbolIcon Symbol="Page" Foreground="#7C3AED"/>
                                <TextBlock Text="فاتورة رقم 2" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding ShowFinalAggregationCommand}"
                                Style="{StaticResource ModernToolbarButtonStyle}"
                                Background="#EAFBF3"
                                Foreground="#166534">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <SymbolIcon Symbol="Sort" Foreground="#16A34A"/>
                                <TextBlock Text="التجميع النهائي" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding ShowTransactionStatementCommand}"
                                Style="{StaticResource ModernToolbarButtonStyle}"
                                Background="#EAF4FF"
                                Foreground="#1D4ED8">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <SymbolIcon Symbol="List" Foreground="#2563EB"/>
                                <TextBlock Text="كشف المعاملات" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Background="#FFFFFF"
                CornerRadius="20"
                BorderBrush="#D4E6F8"
                BorderThickness="1"
                Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="#E7F0FA"
                        CornerRadius="20,20,0,0"
                        Padding="14,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="190"/>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="220"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="رقم مسلسل" FontSize="15" FontWeight="Bold" Foreground="#1D3E63" TextAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="رقم الفاتورة" FontSize="15" FontWeight="Bold" Foreground="#1D3E63" TextAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="التاريخ" FontSize="15" FontWeight="Bold" Foreground="#1D3E63" TextAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="العميل" FontSize="15" FontWeight="Bold" Foreground="#1D3E63" TextAlignment="Center"/>
                        <TextBlock Grid.Column="4" Text="الشركة" FontSize="15" FontWeight="Bold" Foreground="#1D3E63" TextAlignment="Center"/>
                        <TextBlock Grid.Column="5" Text="الموظف" FontSize="15" FontWeight="Bold" Foreground="#1D3E63" TextAlignment="Center"/>
                        <TextBlock Grid.Column="6" Text="الحالة" FontSize="15" FontWeight="Bold" Foreground="#1D3E63" TextAlignment="Center"/>
                        <TextBlock Grid.Column="7" Text="الإجراءات" FontSize="15" FontWeight="Bold" Foreground="#1D3E63" TextAlignment="Center"/>
                    </Grid>
                </Border>

                <ListView Grid.Row="1"
                          ItemsSource="{Binding InvoiceRows}"
                          SelectionMode="None"
                          IsItemClickEnabled="False"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          Background="Transparent"
                          BorderThickness="0"
                          Padding="0">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="UseSystemFocusVisuals" Value="False"/>
                        </Style>
                    </ListView.ItemContainerStyle>

                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#EDF3F9" BorderThickness="0,0,0,1" Padding="14,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="130"/>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="190"/>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="220"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="{Binding SerialNumber}" FontSize="14" Foreground="#244C71" TextAlignment="Center" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding InvoiceNumber}" FontSize="14" FontWeight="Bold" Foreground="#1B4E80" TextAlignment="Center" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding TransactionDateText}" FontSize="14" Foreground="#3A4F63" TextAlignment="Center" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="3" Text="{Binding CustomerName}" FontSize="14" FontWeight="SemiBold" Foreground="#273F58" TextAlignment="Center" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="4" Text="{Binding CompanyName}" FontSize="14" Foreground="#273F58" TextAlignment="Center" TextWrapping="WrapWholeWords" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="5" Text="{Binding EmployeeName}" FontSize="14" Foreground="#273F58" TextAlignment="Center" VerticalAlignment="Center"/>

                                    <Border Grid.Column="6"
                                            Background="#EAF6EE"
                                            BorderBrush="#B9E2C2"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="10,5"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Status}" Foreground="#2E7D32" FontSize="13" FontWeight="SemiBold"/>
                                    </Border>

                                    <StackPanel Grid.Column="7" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <Button Command="{Binding DataContext.ViewTransactionCommand, ElementName=InvoicesPageRoot}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource RowActionButtonStyle}"
                                                Background="#EFF7FF"
                                                BorderBrush="#9FC6EA"
                                                Foreground="#0F5E9C">
                                            <TextBlock Text="عرض"/>
                                        </Button>
                                        <Button Command="{Binding DataContext.ShowInvoiceCommand, ElementName=InvoicesPageRoot}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource RowActionButtonStyle}"
                                                Background="#E8F3FF"
                                                BorderBrush="#6EADE6"
                                                Foreground="#0B62A2">
                                            <TextBlock Text="فاتورة"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <Border Grid.Row="2"
                        Background="#F8FBFF"
                        CornerRadius="0,0,20,20"
                        Padding="16,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="1"
                                   Text="{Binding TotalAmountText}"
                                   FontSize="15"
                                   FontWeight="Bold"
                                   Foreground="#0B62A2"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Page>
