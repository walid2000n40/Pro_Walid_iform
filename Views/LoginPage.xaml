<Page
    x:Class="ProWalid.Views.LoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#E3F2FD" Offset="0.0"/>
                <GradientStop Color="#BBDEFB" Offset="0.5"/>
                <GradientStop Color="#90CAF9" Offset="1.0"/>
            </LinearGradientBrush>
        </Grid.Background>

        <Grid HorizontalAlignment="Center" VerticalAlignment="Center" 
              Width="520" MaxWidth="520">
            
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="16"
                    BorderThickness="1"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                <Border.Shadow>
                    <ThemeShadow />
                </Border.Shadow>
                
                <StackPanel Padding="48,40" Spacing="24">
                    
                    <StackPanel Spacing="8" HorizontalAlignment="Center">
                        <TextBlock Text="Pro Walid" 
                                   FontSize="32" 
                                   FontWeight="Bold"
                                   HorizontalAlignment="Center"
                                   Foreground="#0078D4"/>
                        <TextBlock Text="نظام إدارة المعاملات" 
                                   FontSize="16" 
                                   HorizontalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>

                    <StackPanel Spacing="20">
                        
                        <StackPanel Spacing="8">
                            <TextBlock Text="اسم المستخدم" 
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                            <TextBox x:Name="UsernameTextBox"
                                     Text="{Binding Username, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PlaceholderText="أدخل اسم المستخدم"
                                     Height="48"
                                     FontSize="15"
                                     CornerRadius="8"
                                     BorderThickness="1.5"/>
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock Text="كلمة المرور" 
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                            <PasswordBox x:Name="PasswordTextBox"
                                         Password="{Binding Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         PlaceholderText="أدخل كلمة المرور"
                                         Height="48"
                                         FontSize="15"
                                         CornerRadius="8"
                                         BorderThickness="1.5"/>
                        </StackPanel>

                        <CheckBox Content="تذكرني" 
                                  IsChecked="{Binding RememberMe, Mode=TwoWay}"
                                  FontSize="14"
                                  Margin="0,4,0,0"/>

                        <Button x:Name="LoginButton"
                                Command="{Binding LoginCommand}"
                                HorizontalAlignment="Stretch"
                                Height="52"
                                CornerRadius="8"
                                FontSize="16"
                                FontWeight="SemiBold"
                                Margin="0,8,0,0">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#0078D4"/>
                                    <Setter Property="Foreground" Value="White"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Grid x:Name="RootGrid" Background="{TemplateBinding Background}" 
                                                      CornerRadius="{TemplateBinding CornerRadius}">
                                                    <VisualStateManager.VisualStateGroups>
                                                        <VisualStateGroup x:Name="CommonStates">
                                                            <VisualState x:Name="Normal"/>
                                                            <VisualState x:Name="PointerOver">
                                                                <VisualState.Setters>
                                                                    <Setter Target="RootGrid.Background" Value="#106EBE"/>
                                                                </VisualState.Setters>
                                                            </VisualState>
                                                            <VisualState x:Name="Pressed">
                                                                <VisualState.Setters>
                                                                    <Setter Target="RootGrid.Background" Value="#005A9E"/>
                                                                </VisualState.Setters>
                                                            </VisualState>
                                                            <VisualState x:Name="Disabled">
                                                                <VisualState.Setters>
                                                                    <Setter Target="RootGrid.Background" Value="#CCCCCC"/>
                                                                </VisualState.Setters>
                                                            </VisualState>
                                                        </VisualStateGroup>
                                                    </VisualStateManager.VisualStateGroups>
                                                    <ContentPresenter x:Name="ContentPresenter"
                                                                      Content="{TemplateBinding Content}"
                                                                      HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"
                                                                      Foreground="{TemplateBinding Foreground}"/>
                                                </Grid>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <SymbolIcon Symbol="Contact" Foreground="White"/>
                                <TextBlock Text="تسجيل الدخول" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                    </StackPanel>

                    <TextBlock x:Name="ErrorMessage"
                               Text="{Binding ErrorMessage, Mode=OneWay}"
                               Foreground="#D32F2F"
                               FontSize="14"
                               TextWrapping="Wrap"
                               HorizontalAlignment="Center"
                               Visibility="{Binding HasError, Mode=OneWay}"/>

                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
