<Page
    x:Class="ProWalid.Views.InvoicePreviewPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    FontFamily="{StaticResource AppFontFamily}"
    FlowDirection="RightToLeft">

    <Page.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#F6FAFF" Offset="0"/>
            <GradientStop Color="#EAF3FF" Offset="0.55"/>
            <GradientStop Color="#DDEBFF" Offset="1"/>
        </LinearGradientBrush>
    </Page.Background>

    <Grid Padding="26,22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#FFFFFF"
                BorderBrush="#D9E6F4"
                BorderThickness="1"
                CornerRadius="20"
                Padding="18"
                Margin="0,0,0,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Command="{Binding GoBackCommand}"
                        Background="#EFF6FF"
                        Foreground="#1D4ED8"
                        BorderBrush="#BFDBFE"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="14,8">
                    <TextBlock Text="رجوع"/>
                </Button>

                <StackPanel Grid.Column="2" HorizontalAlignment="Right" Spacing="4">
                    <TextBlock Text="معاينة الفاتورة"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="#123B66"
                               TextAlignment="Right"/>
                    <TextBlock Text="عرض مباشر لمعاينة الفاتورة مع أوامر الحفظ والطباعة فقط"
                               FontSize="14"
                               Foreground="#52708E"
                               TextAlignment="Right"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1"
              RowSpacing="16"
              FlowDirection="LeftToRight">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="#FFFFFF"
                    BorderBrush="#D9E6F4"
                    BorderThickness="1"
                    CornerRadius="18"
                    Padding="18">
                <Grid ColumnSpacing="14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
                        <Button Click="PrintInvoiceButton_Click"
                                Background="#E8F5E9"
                                Foreground="#1B5E20"
                                BorderBrush="#A5D6A7"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="14,8">
                            <TextBlock Text="طباعة A4"/>
                        </Button>

                        <Button Click="SaveInvoiceButton_Click"
                                IsEnabled="{Binding CanSaveInvoice}"
                                Background="#EAFBF3"
                                Foreground="#166534"
                                BorderBrush="#A7E0BC"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="14,8">
                            <TextBlock Text="حفظ الفاتورة"/>
                        </Button>

                        <Button Click="SavePdfButton_Click"
                                Background="#FFF4E8"
                                Foreground="#9A4A00"
                                BorderBrush="#F5C58A"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="14,8">
                            <TextBlock Text="حفظ PDF"/>
                        </Button>
                    </StackPanel>

                    <StackPanel Grid.Column="0" HorizontalAlignment="Right" Spacing="4">
                        <TextBlock Text="معاينة الطباعة بقياس A4"
                                   FontSize="26"
                                   FontWeight="Bold"
                                   Foreground="#123B66"
                                   TextAlignment="Right"/>
                        <TextBlock Text="هذه هي المعاينة المباشرة المعتمدة للفواتير مع أوامر الحفظ والطباعة فقط."
                                   FontSize="13"
                                   Foreground="#52708E"
                                   TextAlignment="Right"
                                   TextWrapping="WrapWholeWords"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid x:Name="PdfRenderHost"
                  Grid.Row="1"
                  HorizontalAlignment="Left"
                  VerticalAlignment="Top"
                  Opacity="0"
                  IsHitTestVisible="False"
                  FlowDirection="LeftToRight"/>

            <Border Grid.Row="1"
                    Background="#FFFFFF"
                    BorderBrush="#D9E6F4"
                    BorderThickness="1"
                    CornerRadius="18"
                    Padding="12"
                    FlowDirection="LeftToRight">
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollMode="Auto"
                              VerticalScrollMode="Auto"
                              ZoomMode="Disabled"
                              Padding="16">
                    <Grid HorizontalAlignment="Center"
                          VerticalAlignment="Top"
                          FlowDirection="LeftToRight">
                        <Border Width="794"
                                Height="1123"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Top"
                                FlowDirection="LeftToRight"
                                Background="White"
                                BorderBrush="#C8DCEF"
                                BorderThickness="1"
                                CornerRadius="10">
                            <Grid HorizontalAlignment="Stretch"
                                  VerticalAlignment="Stretch"
                                  FlowDirection="LeftToRight">
                                <WebView2 x:Name="A4PrintWebView"
                                          DefaultBackgroundColor="White"
                                          FlowDirection="LeftToRight"
                                          HorizontalAlignment="Stretch"
                                          VerticalAlignment="Stretch"/>
                            </Grid>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Page>
